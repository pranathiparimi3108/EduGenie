# -----------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python

# -----------------------
# Virtual Environment
# -----------------------
venv/
.venv/
env/
ENV/

# -----------------------
# Environment Variables
# -----------------------
.env
.env.local
.env.*

# -----------------------
# Flask
# -----------------------
instance/
.flaskenv

# -----------------------
# Streamlit
# -----------------------
.streamlit/

# -----------------------
# VS Code
# -----------------------
.vscode/

# -----------------------
# PyCharm
# -----------------------
.idea/

# -----------------------
# Jupyter Notebook
# -----------------------
.ipynb_checkpoints/

# -----------------------
# Testing
# -----------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.cache/

# -----------------------
# Logs
# -----------------------
*.log

# -----------------------
# Build Files
# -----------------------
build/
dist/
*.egg-info/

# -----------------------
# Operating System
# -----------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------
# Temporary Files
# -----------------------
*.tmp
*.temp
*.bak

# -----------------------
# Media (Optional)
# Uncomment if needed
# -----------------------
# *.mp4
# *.zip

# -----------------------
# API Keys & Secrets
# -----------------------
credentials.json
secret.json
config_local.py
